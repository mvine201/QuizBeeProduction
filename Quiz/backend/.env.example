PORT=5001
MONGO_URI=
JWT_SECRET=
GEMINI_API_KEY=

# Gmail App Password, not the normal Gmail login password.
# Spaces copied from Google App Password are stripped by the mailer.
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Optional HTTP email provider. Recommended on Render free services because
# outbound SMTP ports can be blocked there.
RESEND_API_KEY=
RESEND_FROM=

# Optional SMTP override. Leave empty to use Gmail service.
SMTP_HOST=
SMTP_PORT=587

FRONTEND_URL=
